DISCORD_TOKEN=your_discord_bot_token_here
GROQ_API_KEY=your_groq_api_key_here

# Optional
DISCORD_CLIENT_ID=
GROQ_MODEL=llama-3.3-70b-versatile
COMMAND_PREFIX=!
DATABASE_PATH=./data/bot.sqlite
LOG_LEVEL=info

# Optional tuning
REPLY_CHANCE=0.15
KEYWORD_REPLY_CHANCE=0.35
CHANNEL_COOLDOWN_SECONDS=60
USER_COOLDOWN_SECONDS=25
DECISION_SCORE_THRESHOLD=35
ACTIVE_CONVERSATION_USERS=3
FOMO_MESSAGE_COUNT=60
REACTION_CHANCE=0.05
EMOJI_ONLY_CHANCE=0.08
IMPERFECTION_CHANCE=0.08
PERSONALITY_MODE=mood
TYPING_MIN_MS=1800
TYPING_MAX_MS=4500
TYPING_CHARS_PER_SECOND=8
